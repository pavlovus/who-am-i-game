<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" styleClass="background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.whoami.client.ui.controllers.PostGameController">
    <children>
        <VBox alignment="CENTER" spacing="24" styleClass="card" maxWidth="400">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <children>
                <Label text="Game Over!" styleClass="h1" />
                
                <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #1a2e1f; -fx-background-radius: 8; -fx-padding: 16;">
                    <Label text="Winner:" styleClass="text-muted"/>
                    <Label fx:id="winnerLabel" text="[WINNER]" styleClass="h2" style="-fx-text-fill: #00d46a;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="8">
                    <Label text="The character was:" styleClass="text-muted"/>
                    <Label fx:id="characterLabel" text="[CHARACTER]" styleClass="h2"/>
                </VBox>
                
                <Label fx:id="questionsLabel" text="Questions used: 0" styleClass="text-muted"/>

                <Label fx:id="statusLabel" textFill="#f85149" visible="false" managed="false"/>

                <VBox spacing="16" alignment="CENTER">
                    <VBox.margin>
                        <Insets top="24"/>
                    </VBox.margin>
                    <Button fx:id="rematchBtn" text="Request Rematch" onAction="#handleRematch" styleClass="button-primary" maxWidth="Infinity"/>
                    <Button text="Leave Room" onAction="#handleLeave" styleClass="button-ghost" maxWidth="Infinity"/>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
